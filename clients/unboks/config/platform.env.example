AZURE_CLIENT_ID=
AZURE_TENANT_ID=

# Google service account key (shared)
GOOGLE_WORKSPACE_CLI_CREDENTIALS_FILE=/app/config/calendar-key.json

# WhatsApp (disabled — no channel connected yet)
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
