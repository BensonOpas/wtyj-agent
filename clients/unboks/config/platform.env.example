# Unboks (internal test sandbox) platform.env — fill in real values on the VPS.
# This file is the template. Real platform.env lives in
# /root/clients/unboks/config/platform.env on the VPS and is NOT tracked.

# Anthropic (shared across all clients for now)
ANTHROPIC_API_KEY=

# Dashboard
DASHBOARD_PASSWORD=papaesunmono

# Email (disabled — internal sandbox, no inbound email)
